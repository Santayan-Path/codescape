{
  "name": "codescape",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r --filter @codescape/core --filter @codescape/cli build",
    "build:core": "pnpm --filter @codescape/core build",
    "build:cli": "pnpm --filter @codescape/cli build",
    "build:dashboard": "pnpm --filter @codescape/dashboard build",
    "dev:dashboard": "pnpm --filter @codescape/dashboard dev",
    "analyze": "npx tsx cli/src/index.ts"
  },
  "devDependencies": {
    "@types/node": "^25.0.0",
    "eslint": "^9.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.1.0"
  }
}
