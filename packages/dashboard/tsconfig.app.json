{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "noEmit": true,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@codescape/core": ["../core/src/index.ts"],
      "@codescape/core/types": ["../core/src/types.ts"],
      "@codescape/core/schema": ["../core/src/schema.ts"],
      "@codescape/core/search": ["../core/src/search.ts"]
    }
  },
  "include": ["src"]
}
